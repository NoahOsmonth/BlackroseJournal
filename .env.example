# Copy this file to ".env" and fill in values.
# Never commit real secrets to git.

# NanoGPT (used by services/ai.ts)
# In Expo runtime, only EXPO_PUBLIC_* variables are guaranteed to be available.
NANO_GPT_API_KEY=YOUR_NANO_GPT_API_KEY
NANO_GPT_API_BASE_URL=https://nano-gpt.com/api/v1
NANO_GPT_MODEL=zai-org/glm-4.7-original:thinking
NANO_GPT_FLASH_MODEL=zai-org/glm-4.7-flash-original

EXPO_PUBLIC_NANO_GPT_API_KEY=YOUR_NANO_GPT_API_KEY
EXPO_PUBLIC_NANO_GPT_API_BASE_URL=https://nano-gpt.com/api/v1
EXPO_PUBLIC_NANO_GPT_MODEL=zai-org/glm-4.7-original:thinking
EXPO_PUBLIC_NANO_GPT_FLASH_MODEL=zai-org/glm-4.7-flash-original

# Supermemory (optional)
SUPERMEMORY_API_KEY=YOUR_SUPERMEMORY_API_KEY
SUPERMEMORY_BASE_URL=https://api.supermemory.ai
