# Copy this file to ".env" and fill in values.
# Never commit real secrets to git.

# NanoGPT (used by services/ai.ts)
# In Expo runtime, only EXPO_PUBLIC_* variables are guaranteed to be available.
NANO_GPT_API_KEY=YOUR_NANO_GPT_API_KEY
NANO_GPT_API_BASE_URL=https://nano-gpt.com/api/v1
NANO_GPT_MODEL=moonshotai/kimi-k2.5:thinking
NANO_GPT_FLASH_MODEL=moonshotai/kimi-k2.5

# Agent backend (chat)
AGENT_BASE_URL=http://localhost:8787
EXPO_PUBLIC_AGENT_BASE_URL=http://localhost:8787

# Supabase (database + storage)
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
EXPO_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
